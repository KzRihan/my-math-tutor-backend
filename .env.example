# =================================
# Application Configuration
# =================================
NODE_ENV=development
PORT=3000
API_VERSION=v1

# =================================
# MongoDB Configuration
# =================================
MONGODB_URI=mongodb://localhost:27017/my-math-tutor
MONGODB_MIN_POOL_SIZE=5
MONGODB_MAX_POOL_SIZE=20

# =================================
# Redis Configuration
# =================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =================================
# Queue Configuration
# =================================
QUEUE_EMAIL_NAME=email-queue
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000

# =================================
# Logging Configuration
# =================================
LOG_LEVEL=debug
LOG_FORMAT=json

# =================================
# Rae Limiting
# =================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# Email Configuration (Example)
# =================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com

# =================================
# JWT Configuration
# =================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=7d

# =================================
# OCR Service Configuration
# =================================
OCR_API_URL=http://localhost:8501/ocr

# =================================
# Agent / AI Service Configuration
# =================================
AGENT_API_URL=http://localhost:8502
AI_SERVICE_URL=http://localhost:8503
